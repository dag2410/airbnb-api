<% const s = summary; %>

<div class="content-header analytics-header">
  <div>
    <h1><%= title %></h1>
    <p class="text-muted">
      <%= range.label %> · <%= range.startDateStr %> → <%= range.endDateStr %>
    </p>
  </div>
  <div class="header-actions">
    <a href="/admin/analytics?range=<%= range.preset %>" class="btn btn-secondary">
      <i class="fas fa-sync-alt"></i> Làm mới
    </a>
  </div>
</div>

<!-- Bộ lọc thời gian -->
<div class="card analytics-filter-card">
  <form method="GET" action="/admin/analytics" class="filter-form analytics-filter-form">
    <div class="form-group">
      <label for="dateRange">Khoảng thời gian</label>
      <select id="dateRange" name="range" class="form-control">
        <option value="today" <%= range.preset === 'today' ? 'selected' : '' %>>Hôm nay</option>
        <option value="yesterday" <%= range.preset === 'yesterday' ? 'selected' : '' %>>Hôm qua</option>
        <option value="week" <%= range.preset === 'week' ? 'selected' : '' %>>7 ngày qua</option>
        <option value="month" <%= range.preset === 'month' ? 'selected' : '' %>>30 ngày qua</option>
        <option value="quarter" <%= range.preset === 'quarter' ? 'selected' : '' %>>90 ngày qua</option>
        <option value="year" <%= range.preset === 'year' ? 'selected' : '' %>>365 ngày qua</option>
        <option value="custom" <%= range.preset === 'custom' ? 'selected' : '' %>>Tùy chọn</option>
      </select>
    </div>
    <div id="customDateWrap" class="custom-date-wrap" style="<%= range.preset === 'custom' ? '' : 'display:none' %>">
      <div class="form-group">
        <label for="customDateStart">Từ ngày</label>
        <input type="date" id="customDateStart" name="startDate" class="form-control" value="<%= range.startDateStr %>" />
      </div>
      <div class="form-group">
        <label for="customDateEnd">Đến ngày</label>
        <input type="date" id="customDateEnd" name="endDate" class="form-control" value="<%= range.endDateStr %>" />
      </div>
    </div>
    <div class="form-group filter-actions">
      <button type="submit" class="btn btn-primary"><i class="fas fa-filter"></i> Áp dụng</button>
    </div>
  </form>
</div>

<!-- KPI cards -->
<div class="stats-grid analytics-stats">
  <%- include('../components/analytics-stat-card', { title: 'Doanh thu', value: s.revenue.value, change: s.revenue.change, trend: s.revenue.trend, icon: 'fa-coins' }) %>
  <%- include('../components/analytics-stat-card', { title: 'Tổng booking', value: s.bookings.value, change: s.bookings.change, trend: s.bookings.trend, icon: 'fa-calendar-check' }) %>
  <%- include('../components/analytics-stat-card', { title: 'User mới', value: s.newUsers.value, change: s.newUsers.change, trend: s.newUsers.trend, icon: 'fa-user-plus' }) %>
  <%- include('../components/analytics-stat-card', { title: 'Giá trị TB/booking', value: s.avgBookingValue.value, change: s.avgBookingValue.change, trend: s.avgBookingValue.trend, icon: 'fa-chart-line' }) %>
  <%- include('../components/analytics-stat-card', { title: 'Thanh toán thành công', value: s.paidPayments.value, change: s.paidPayments.change, trend: s.paidPayments.trend, icon: 'fa-credit-card' }) %>
  <%- include('../components/analytics-stat-card', { title: 'Tỷ lệ chuyển đổi', value: s.conversionRate.value, change: s.conversionRate.change, trend: s.conversionRate.trend, icon: 'fa-percentage', percent: true }) %>
</div>

<!-- Biểu đồ chính -->
<div class="charts-grid analytics-charts">
  <div class="card chart-card chart-card-wide">
    <div class="card-header"><h3>Doanh thu theo thời gian</h3></div>
    <div class="card-body"><div class="chart-container chart-lg"><canvas id="revenueChart"></canvas></div></div>
  </div>

  <div class="card chart-card chart-card-wide">
    <div class="card-header"><h3>Booking theo thời gian</h3></div>
    <div class="card-body"><div class="chart-container chart-lg"><canvas id="bookingsChart"></canvas></div></div>
  </div>

  <div class="card chart-card">
    <div class="card-header"><h3>User đăng ký mới</h3></div>
    <div class="card-body"><div class="chart-container"><canvas id="newUsersChart"></canvas></div></div>
  </div>

  <div class="card chart-card">
    <div class="card-header"><h3>Trạng thái booking</h3></div>
    <div class="card-body"><div class="chart-container"><canvas id="bookingStatusChart"></canvas></div></div>
  </div>

  <div class="card chart-card">
    <div class="card-header"><h3>Doanh thu theo cổng thanh toán</h3></div>
    <div class="card-body"><div class="chart-container"><canvas id="paymentProviderChart"></canvas></div></div>
  </div>

  <div class="card chart-card">
    <div class="card-header"><h3>Trạng thái giao dịch</h3></div>
    <div class="card-body"><div class="chart-container"><canvas id="paymentStatusChart"></canvas></div></div>
  </div>

  <div class="card chart-card">
    <div class="card-header"><h3>Top thành phố (booking)</h3></div>
    <div class="card-body"><div class="chart-container"><canvas id="topCitiesChart"></canvas></div></div>
  </div>

  <div class="card chart-card chart-card-wide">
    <div class="card-header"><h3>Top phòng (doanh thu & booking)</h3></div>
    <div class="card-body"><div class="chart-container chart-lg"><canvas id="topRoomsChart"></canvas></div></div>
  </div>
</div>

<!-- Bảng chi tiết top phòng -->
<div class="card">
  <div class="card-header"><h3>Chi tiết phòng hiệu suất cao</h3></div>
  <div class="card-body">
    <% if (!topRooms || !topRooms.length) { %>
      <%- include('../components/empty-state', { title: 'Chưa có dữ liệu phòng', message: 'Thử chọn khoảng thời gian khác.' }) %>
    <% } else { %>
      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Phòng</th>
              <th>Thành phố</th>
              <th>Số booking</th>
              <th>Doanh thu</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% topRooms.forEach(function(row, i) { %>
              <tr>
                <td><%= i + 1 %></td>
                <td><%= row.title %></td>
                <td><%= row.city %></td>
                <td><%= row.booking_count %></td>
                <td><%= formatCurrency(row.total_revenue) %></td>
                <td>
                  <%- include('../components/action-buttons', { viewUrl: '/admin/rooms/' + row.room_id }) %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<link rel="stylesheet" href="/assets/css/analytics.css" />
<script>
  window.analyticsCharts = <%- chartsJson %>;
  window.topCitiesData = {
    labels: <%- JSON.stringify((topCities || []).map(c => c.city)) %>,
    data: <%- JSON.stringify((topCities || []).map(c => c.booking_count)) %>
  };
  window.topRoomsChartData = {
    labels: <%- JSON.stringify((topRooms || []).slice(0, 8).map(r => r.title.length > 20 ? r.title.slice(0, 20) + '…' : r.title)) %>,
    revenue: <%- JSON.stringify((topRooms || []).slice(0, 8).map(r => r.total_revenue)) %>,
    bookings: <%- JSON.stringify((topRooms || []).slice(0, 8).map(r => r.booking_count)) %>
  };
</script>
<script src="/assets/js/admin-analytics.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (window.initAdminAnalytics && window.analyticsCharts) {
      window.initAdminAnalytics(window.analyticsCharts);
    }
  });
</script>
