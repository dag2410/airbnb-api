<%
  const isEdit = typeof formAction !== 'undefined' && formAction.includes('_method=PUT');
%>
<div class="form-row">
  <div class="form-group">
    <label for="first_name">Họ</label>
    <input type="text" id="first_name" name="first_name" class="form-control" value="<%= old.first_name || '' %>" />
    <% if (errors.first_name) { %><span class="error-text"><%= errors.first_name %></span><% } %>
  </div>
  <div class="form-group">
    <label for="last_name">Tên</label>
    <input type="text" id="last_name" name="last_name" class="form-control" value="<%= old.last_name || '' %>" />
    <% if (errors.last_name) { %><span class="error-text"><%= errors.last_name %></span><% } %>
  </div>
</div>

<div class="form-group">
  <label for="email">Email *</label>
  <input type="email" id="email" name="email" class="form-control" value="<%= old.email || '' %>" required />
  <% if (errors.email) { %><span class="error-text"><%= errors.email %></span><% } %>
</div>

<div class="form-group">
  <label for="username">Username</label>
  <input type="text" id="username" name="username" class="form-control" value="<%= old.username || '' %>" />
  <% if (errors.username) { %><span class="error-text"><%= errors.username %></span><% } %>
</div>

<div class="form-group">
  <label for="phone_number">Số điện thoại</label>
  <input type="text" id="phone_number" name="phone_number" class="form-control" value="<%= old.phone_number || '' %>" />
  <% if (errors.phone_number) { %><span class="error-text"><%= errors.phone_number %></span><% } %>
</div>

<div class="form-group">
  <label for="role_id">Vai trò</label>
  <select id="role_id" name="role_id" class="form-control">
    <% if (typeof roles !== 'undefined') { roles.forEach(function(role) { %>
      <option value="<%= role.id %>" <%= String(old.role_id) === String(role.id) ? 'selected' : '' %>><%= role.name %></option>
    <% }); } %>
  </select>
</div>

<div class="form-group">
  <label for="password"><%= isEdit ? 'Mật khẩu mới (để trống nếu không đổi)' : 'Mật khẩu *' %></label>
  <input type="password" id="password" name="password" class="form-control" <%= isEdit ? '' : 'required minlength="8"' %> />
  <% if (errors.password) { %><span class="error-text"><%= errors.password %></span><% } %>
</div>

<% if (!isEdit) { %>
<div class="form-group">
  <label for="confirm_password">Xác nhận mật khẩu *</label>
  <input type="password" id="confirm_password" name="confirm_password" class="form-control" required />
  <% if (errors.confirm_password) { %><span class="error-text"><%= errors.confirm_password %></span><% } %>
</div>
<% } %>
