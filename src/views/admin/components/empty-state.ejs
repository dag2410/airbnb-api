<%
  const iconClass =
    typeof icon !== 'undefined' && icon ? icon : 'fa-inbox';
  const emptyTitle =
    typeof title !== 'undefined' && title ? title : 'Không có dữ liệu';
  const emptyMessage =
    typeof message !== 'undefined' && message
      ? message
      : 'Chưa có bản ghi nào phù hợp với bộ lọc hiện tại.';
  const btnLabel =
    typeof actionLabel !== 'undefined' && actionLabel ? actionLabel : 'Thêm mới';
%>
<div class="empty-state">
  <i class="fas <%= iconClass %>"></i>
  <h3><%= emptyTitle %></h3>
  <p><%= emptyMessage %></p>
  <% if (typeof actionUrl !== 'undefined' && actionUrl) { %>
    <a href="<%= actionUrl %>" class="btn btn-primary"><%= btnLabel %></a>
  <% } %>
</div>
