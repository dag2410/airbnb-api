<%- include('../components/page-header', { title: title }) %>
<div style="display:flex;gap:10px;margin-bottom:16px;">
  <a href="/admin/users" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
  <a href="/admin/users/<%= user.id %>/edit" class="btn btn-primary">Sửa</a>
</div>

<div class="detail-card">
  <p><strong>Họ tên:</strong> <%= getDisplayName(user) %></p>
  <p><strong>Email:</strong> <%= user.email %></p>
  <p><strong>Username:</strong> <%= user.username || '—' %></p>
  <p><strong>Điện thoại:</strong> <%= user.phone_number || '—' %></p>
  <p><strong>Vai trò:</strong> <%= user.role?.name || user.role_id %></p>
  <p><strong>Ngày tạo:</strong> <%= formatDate(user.created_at) %></p>
  <p><strong>Đăng nhập gần nhất:</strong> <%= formatDate(user.last_login) %></p>
</div>
