<%- include('../components/page-header', { title: title }) %>
<a href="/admin/users/create" class="btn btn-primary" style="margin-bottom:16px;"><i class="fas fa-plus"></i> Thêm người dùng</a>

<%- include('../components/search-form', { action: '/admin/users', label: 'Tìm user', placeholder: 'Email, username, tên...' }) %>
<%- include('../components/filter-bar', {
  action: '/admin/users',
  filters: typeof roleOptions !== 'undefined' ? [
    { name: 'role_id', label: 'Vai trò', type: 'select', options: roleOptions.map(r => ({ value: r.id, label: r.name })) }
  ] : []
}) %>

<div class="table-container">
  <% if (!users.length) { %>
    <%- include('../components/empty-state', { title: 'Chưa có user', message: 'Thử đổi bộ lọc hoặc tạo user mới.', actionUrl: '/admin/users/create', actionLabel: 'Tạo user' }) %>
  <% } else { %>
    <table class="data-table">
      <thead>
        <tr>
          <th>Người dùng</th>
          <th>Email</th>
          <th>Vai trò</th>
          <th>Ngày tạo</th>
          <th>Thao tác</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(function(user) { %>
          <tr>
            <td><%= getDisplayName(user) %></td>
            <td><%= user.email %></td>
            <td><%= user.role?.name || user.role_id %></td>
            <td><%= formatDate(user.createdAt) %></td>
            <td>
              <%- include('../components/action-buttons', {
                viewUrl: '/admin/users/' + user.id,
                editUrl: '/admin/users/' + user.id + '/edit',
                deleteUrl: '/admin/users/' + user.id,
                confirmMessage: 'Xóa user ' + getDisplayName(user) + '?'
              }) %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
    <%
      const qs = Object.entries(query || {}).filter(([k,v]) => v && k !== 'page').map(([k,v]) => k + '=' + encodeURIComponent(v)).join('&');
    %>
    <%- include('../components/pagination', { pagination, baseUrl: '/admin/users', queryString: qs }) %>
  <% } %>
</div>
