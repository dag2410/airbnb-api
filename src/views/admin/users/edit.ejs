<%- include('../components/page-header', { title: title, subtitle: 'ID: ' + user.id }) %>
<div style="display:flex;gap:10px;margin-bottom:16px;">
  <a href="/admin/users" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
  <a href="/admin/users/<%= user.id %>" class="btn btn-secondary">Xem chi tiết</a>
</div>

<div class="card" style="padding:24px;">
  <form method="POST" action="/admin/users/<%= user.id %>?_method=PUT">
    <%- include('../components/user-form', { old, errors, roles }) %>
    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
  </form>
  <form method="POST" action="/admin/users/<%= user.id %>?_method=DELETE" class="inline-form" style="margin-top:16px;" data-item-name="user #<%= user.id %>">
    <button type="submit" class="btn btn-danger">Xóa người dùng</button>
  </form>
</div>
