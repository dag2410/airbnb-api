<div class="content-header">
  <h1><%= title %></h1>
  <a href="/admin/wallets" class="btn btn-secondary">← Quay lại</a>
</div>

<div class="detail-card">
  <p><strong>User:</strong> <%= wallet.user ? getDisplayName(wallet.user) : wallet.user_id %></p>
  <p><strong>Số dư hiện tại:</strong> <%= formatCurrency(wallet.balance) %></p>
  <p><strong>Nhận tiền gần nhất:</strong> <%= formatDate(wallet.last_received_at) %></p>
</div>

<form method="POST" action="/admin/wallets/<%= wallet.id %>/adjust" class="filter-form" style="margin-top: 20px;">
  <div class="form-group">
    <label for="type">Loại giao dịch</label>
    <select name="type" id="type" class="form-control">
      <option value="credit">Cộng tiền</option>
      <option value="debit">Trừ tiền</option>
    </select>
  </div>
  <div class="form-group">
    <label for="amount">Số tiền (VND)</label>
    <input type="number" name="amount" id="amount" class="form-control" min="1" required />
  </div>
  <button type="submit" class="btn btn-primary">Cập nhật số dư</button>
</form>
