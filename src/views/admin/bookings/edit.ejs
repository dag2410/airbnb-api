<div class="content-header">
  <h1><%= title %></h1>
  <a href="/admin/bookings/<%= booking.id %>" class="btn btn-secondary">← Quay lại</a>
</div>

<div class="card" style="padding: 24px;">
  <form method="POST" action="/admin/bookings/<%= booking.id %>?_method=PUT">
    <div class="form-group">
      <label>Trạng thái</label>
      <select name="status" class="form-control">
        <% statusOptions.forEach(function(s) { %>
          <option value="<%= s %>" <%= booking.status === s ? 'selected' : '' %>><%= s %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group">
      <label>Số khách</label>
      <input type="number" name="total_guests" class="form-control" value="<%= booking.total_guests %>" min="1" />
    </div>
    <div class="form-group">
      <label>Tổng tiền</label>
      <input type="number" name="total_price" class="form-control" value="<%= booking.total_price %>" min="0" step="1000" />
    </div>
    <button type="submit" class="btn btn-primary">Lưu</button>
  </form>
</div>
