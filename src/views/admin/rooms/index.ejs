<div class="content-header">
  <h1><%= title %></h1>
  <a href="/admin/rooms/create" class="btn btn-primary"><i class="fas fa-plus"></i> Thêm phòng</a>
</div>

<%- include('../components/search-form', { action: '/admin/rooms', label: 'Tìm phòng', placeholder: 'Tiêu đề phòng...' }) %>

<div class="table-container">
  <% if (!rooms.length) { %>
    <%- include('../components/empty-state', { title: 'Chưa có phòng', actionUrl: '/admin/rooms/create' }) %>
  <% } else { %>
    <table class="data-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Tiêu đề</th>
          <th>Host</th>
          <th>Giá/đêm</th>
          <th>Rating</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% rooms.forEach(function(room) { %>
          <tr>
            <td>#<%= room.id %></td>
            <td><%= room.title %></td>
            <td><%= room.host ? getDisplayName(room.host) : room.user_id %></td>
            <td><%= formatCurrency(room.price_per_night) %></td>
            <td><%= room.rating || '—' %></td>
            <td>
              <%- include('../components/action-buttons', {
                viewUrl: '/admin/rooms/' + room.id,
                editUrl: '/admin/rooms/' + room.id + '/edit',
                deleteUrl: '/admin/rooms/' + room.id,
                confirmMessage: 'Xóa phòng ' + room.title + '?'
              }) %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
    <% const qs = Object.entries(query || {}).filter(([k,v]) => v && k !== 'page').map(([k,v]) => k + '=' + encodeURIComponent(v)).join('&'); %>
    <%- include('../components/pagination', { pagination, baseUrl: '/admin/rooms', queryString: qs }) %>
  <% } %>
</div>
