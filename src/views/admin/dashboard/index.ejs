<%- include('../components/page-header', { title: 'Dashboard', subtitle: 'Tổng quan hệ thống' }) %>

<div class="stats-grid">
  <div class="stat-card">
    <h3>Tổng người dùng</h3>
    <p class="stat-value"><%= stats.totalUsers %></p>
    <div class="stat-icon"><i class="fas fa-users"></i></div>
  </div>
  <div class="stat-card">
    <h3>Tổng booking</h3>
    <p class="stat-value"><%= stats.totalBookings %></p>
    <div class="stat-icon"><i class="fas fa-calendar-check"></i></div>
  </div>
  <div class="stat-card">
    <h3>Tổng payments</h3>
    <p class="stat-value"><%= stats.totalPayments %></p>
    <div class="stat-icon"><i class="fas fa-credit-card"></i></div>
  </div>
  <div class="stat-card">
    <h3>Tổng doanh thu</h3>
    <p class="stat-value"><%= formatCurrency(stats.totalRevenue) %></p>
    <div class="stat-icon"><i class="fas fa-coins"></i></div>
  </div>
</div>

<div class="charts-grid" style="margin-top:24px;">
  <div class="chart-card" style="grid-column:1/-1;">
    <h3 style="padding:16px 16px 0;">Doanh thu theo tháng</h3>
    <div class="chart-container chart-lg" style="height:280px;padding:16px;">
      <canvas id="revenueChart"></canvas>
    </div>
  </div>
</div>

<div class="dashboard-tables" style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:24px;">
  <div class="table-container">
    <h3 style="padding:16px 16px 0;">Booking gần đây</h3>
    <table class="data-table">
      <thead>
        <tr><th>ID</th><th>Phòng</th><th>Giá</th><th>TT</th></tr>
      </thead>
      <tbody>
        <% if (!latestBookings || !latestBookings.length) { %>
          <tr><td colspan="4" class="text-center">Chưa có dữ liệu</td></tr>
        <% } %>
        <% (latestBookings || []).forEach(function(b) { %>
          <tr>
            <td><a href="/admin/bookings/<%= b.id %>">#<%= b.id %></a></td>
            <td><%= b.room?.title || '—' %></td>
            <td><%= formatCurrency(b.total_price) %></td>
            <td><%- include('../components/status-badge', { status: b.status }) %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <div class="table-container">
    <h3 style="padding:16px 16px 0;">Payment gần đây</h3>
    <table class="data-table">
      <thead>
        <tr><th>ID</th><th>Provider</th><th>Số tiền</th><th>TT</th></tr>
      </thead>
      <tbody>
        <% if (!latestPayments || !latestPayments.length) { %>
          <tr><td colspan="4" class="text-center">Chưa có dữ liệu</td></tr>
        <% } %>
        <% (latestPayments || []).forEach(function(p) { %>
          <tr>
            <td><a href="/admin/payments/<%= p.id %>">#<%= p.id %></a></td>
            <td><%= p.provider %></td>
            <td><%= formatCurrency(p.amount) %></td>
            <td><%- include('../components/status-badge', { status: p.status }) %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<script>
  const revenueLabels = <%- JSON.stringify(monthlyRevenueLabels || []) %>;
  const revenueData = <%- JSON.stringify(monthlyRevenueValues || []) %>;
  document.addEventListener('DOMContentLoaded', function () {
    const ctx = document.getElementById('revenueChart');
    if (ctx && typeof Chart !== 'undefined') {
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: revenueLabels,
          datasets: [{ label: 'Doanh thu (VND)', data: revenueData, backgroundColor: 'rgba(58,134,255,0.7)' }],
        },
        options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true } } },
      });
    }
  });
</script>
